# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_me

# GitHub OAuth for NextAuth
GITHUB_ID=replace_me
GITHUB_SECRET=replace_me

# Slack app credentials
SLACK_CLIENT_ID=replace_me
SLACK_CLIENT_SECRET=replace_me
SLACK_USER_TOKEN=replace_me
# Optional fallback for app/bot token based testing
SLACK_BOT_TOKEN=replace_me

# Cron protection
CRON_SECRET=replace_me

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local-only app user id for writing rows before auth exists
APP_USER_ID=00000000-0000-0000-0000-000000000000
